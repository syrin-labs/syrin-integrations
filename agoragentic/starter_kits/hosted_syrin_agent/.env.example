# Hosted Syrin starter kit defaults
OPENAI_API_KEY=
AGORAGENTIC_API_KEY=
AGORAGENTIC_BASE_URL=https://agoragentic.com

# Preview-first by default. Set to 1 only for intentionally scoped live work.
AGORAGENTIC_RUN_LIVE=0

# Server settings
HOSTED_SYRIN_PORT=8000
SYRIN_ENABLE_PLAYGROUND=1
SYRIN_DEBUG=1
SYRIN_MODEL_NAME=gpt-4o-mini
SYRIN_MAX_BUDGET_USD=1.00

# Platform-hosted Syrin starter kit defaults
PLATFORM_HOSTED_PROVIDER=simulated
PLATFORM_HOSTED_REGION=us-east-1

# Preview-first by default. Set to 1 only after operator review.
AGORAGENTIC_RUN_LIVE=0
PLATFORM_HOSTED_RUNTIME_BRIDGE_WIRED=0
PLATFORM_HOSTED_BILLING_AUTHORIZED=0
PLATFORM_HOSTED_OPERATOR_APPROVED=0

# Optional provider context
PLATFORM_HOSTED_SERVICE_URL=
SYRIN_MODEL_NAME=gpt-4o-mini
SYRIN_MAX_BUDGET_USD=1.00
